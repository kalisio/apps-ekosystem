{
  "name": "apps-ekosystem",
  "description": "Monorepo hosting Kalisio applications",
  "type": "module",
  "packageManager": "pnpm@10.1.0",
  "standard": {
    "globals": [
      "describe",
      "it",
      "expect",
      "beforeEach",
      "afterEach",
      "Image"
    ],
    "ignore": [
      "dist/**"
    ]
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "pnpm lint"
    ]
  },
  "scripts": {
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "changeset:release": "pnpm build && changeset publish",
    "lint": "pnpm -r lint",
    "lint:teams:common": "pnpm --filter @kalisio/teams-common lint",
    "lint:teams:api": "pnpm --filter @kalisio/teams-api lint",
    "lint:teams:ui": "pnpm --filter @kalisio/teams-ui lint",
    "prepare": "husky",
    "test": "pnpm -r test --coverage",
    "test:teams:common": "pnpm --filter @kalisio/teams-common test",
    "test:teams:api": "pnpm --filter @kalisio/teams-api test",
    "test:teams:ui": "pnpm --filter @kalisio/teams-ui test"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/apps-ekosystem.git"
  },
  "bugs": {
    "url": "https://github.com/kalisio/apps-ekosystem/issues"
  },
  "homepage": "git://github.com/kalisio/apps-ekosystem#readme",
  "dependencies": {
    "keycloak-js": "catalog:",
    "lodash": "catalog:",
    "moment": "catalog:",
    "quasar": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@kalisio/meta-ekosystem": "github:kalisio/meta-ekosystem",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "mermaid": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vitepress": "catalog:",
    "vitepress-plugin-mermaid": "catalog:",
    "vitepress-theme-kalisio": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@kalisio/meta-ekosystem": "link:../meta-ekosystem",
      "ejs": "^3.1.10"
    }
  }
}
